<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dialog_manual_input_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="8dp"
    android:paddingEnd="20dp"
    android:paddingBottom="4dp">

    <TextView
        android:id="@+id/tv_manual_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/manual_dialog_title"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_manual_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp"
        android:text="@string/manual_dialog_subtitle"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/group_input_mode"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginBottom="16dp"
        app:selectionRequired="true"
        app:singleSelection="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_mode_paste"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/manual_mode_paste"
            android:textColor="@color/mode_button_text"
            android:textSize="13sp"
            app:backgroundTint="@color/mode_button_bg"
            app:cornerRadius="12dp"
            app:strokeColor="@color/border_default"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_mode_manual"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/manual_mode_manual"
            android:textColor="@color/mode_button_text"
            android:textSize="13sp"
            app:backgroundTint="@color/mode_button_bg"
            app:cornerRadius="12dp"
            app:strokeColor="@color/border_default"
            app:strokeWidth="1dp" />

    </com.google.android.material.button.MaterialButtonToggleGroup>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/input_layout_manual"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        android:hint="@string/manual_input_paste_hint"
        app:boxBackgroundColor="@color/bg_card"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusTopStart="12dp"
        app:boxStrokeColor="@color/text_input_stroke"
        app:boxStrokeWidth="1dp"
        app:boxStrokeWidthFocused="2dp"
        app:endIconMode="clear_text"
        app:hintTextColor="@color/accent_primary"
        app:placeholderText="@string/manual_input_paste_placeholder"
        app:placeholderTextColor="@color/text_hint">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_manual_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top|start"
            android:inputType="textMultiLine|textLongMessage"
            android:maxLines="6"
            android:minLines="4"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="15sp" />

    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:id="@+id/layout_type_selector"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_type_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/manual_type_label"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_code_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="8dp"
            app:selectionRequired="true"
            app:singleLine="false"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_type_express"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/manual_type_express"
                android:textColor="@color/chip_choice_text"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_choice_bg"
                app:chipMinHeight="36dp"
                app:chipStrokeColor="@color/border_default"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_type_food"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/manual_type_food"
                android:textColor="@color/chip_choice_text"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_choice_bg"
                app:chipMinHeight="36dp"
                app:chipStrokeColor="@color/border_default"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_type_parking"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/manual_type_parking"
                android:textColor="@color/chip_choice_text"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_choice_bg"
                app:chipMinHeight="36dp"
                app:chipStrokeColor="@color/border_default"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_type_other"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/manual_type_other"
                android:textColor="@color/chip_choice_text"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_choice_bg"
                app:chipMinHeight="36dp"
                app:chipStrokeColor="@color/border_default"
                app:chipStrokeWidth="1dp" />

        </com.google.android.material.chip.ChipGroup>
    </LinearLayout>

</LinearLayout>
