<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/bg_primary"
            app:title="@string/app_name"
            app:titleTextAppearance="@style/TextAppearance.PickCode.Title"
            app:navigationIconTint="@color/text_primary" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- 分类 Tab：未取件 / 已取件 -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_primary"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabTextAppearance="@style/TextAppearance.PickCode.TabText"
        app:tabSelectedTextColor="@color/accent_primary"
        app:tabTextColor="@color/text_hint"
        app:tabIndicatorColor="@color/accent_primary"
        app:tabIndicatorHeight="2dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <!-- 历史列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="100dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        tools:listitem="@layout/item_code_record" />

    <!-- 空状态提示 -->
    <LinearLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="\uD83D\uDCE6"
            android:textSize="52sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="还没有识别记录"
            android:textSize="16sp"
            android:textColor="@color/text_secondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="可截屏识别、通知栏触发、或手动输入取件码"
            android:textSize="13sp"
            android:textColor="@color/text_hint" />

    </LinearLayout>

    <!-- 底部按钮区域（仅手动输入，居中） -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="28dp">

        <!-- 手动输入按钮（主操作） -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnManualInput"
            style="@style/Widget.Material3.Button"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:minWidth="180dp"
            android:paddingHorizontal="28dp"
            android:text="✏️ 手动输入取件码"
            android:textColor="@color/white"
            android:textSize="15sp"
            app:cornerRadius="26dp"
            app:backgroundTint="@color/accent_primary" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
