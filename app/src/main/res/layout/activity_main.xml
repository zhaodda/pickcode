<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/bg_primary"
            app:title="@string/app_name"
            app:titleTextAppearance="@style/TextAppearance.PickCode.Title"
            app:navigationIconTint="@color/text_primary" />

        <!-- 分类 Tab：未取件 / 已取件 -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_primary"
            app:tabMode="fixed"
            app:tabGravity="fill"
            app:tabTextAppearance="@style/TextAppearance.PickCode.TabText"
            app:tabSelectedTextColor="@color/accent_primary"
            app:tabTextColor="@color/text_hint"
            app:tabIndicatorColor="@color/accent_primary"
            app:tabIndicatorHeight="2dp" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ViewPager2：左右滑动切换未取件/已取件 -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="8dp"
        android:paddingBottom="100dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <!-- 底部按钮区域（仅手动输入，居中） -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="28dp">

        <!-- 手动输入按钮（主操作） -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnManualInput"
            style="@style/Widget.Material3.Button"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:minWidth="180dp"
            android:paddingHorizontal="28dp"
            android:text="✏️ 手动输入取件码"
            android:textColor="@color/white"
            android:textSize="15sp"
            app:cornerRadius="26dp"
            app:backgroundTint="@color/accent_primary" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
