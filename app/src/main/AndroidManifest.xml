<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ── 权限声明 ── -->

    <!-- 前台服务权限（截屏必须） -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />

    <!-- 通知权限（Android 13+ 必须申请） -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 开机自启 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- 震动反馈（可选） -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!--
        注意：SYSTEM_ALERT_WINDOW（悬浮窗权限）已移除
        原悬浮窗方案已替换为小米超级岛原生通知接口（miui.focus.param）
        超级岛功能通过标准通知实现，无需悬浮窗权限
    -->

    <application
        android:name=".PickCodeApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PickCode"
        tools:targetApi="31">

        <!-- 主界面 -->
        <activity
            android:name=".ui.activity.MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 权限请求透明 Activity（截屏权限申请专用） -->
        <activity
            android:name=".ui.activity.PermissionActivity"
            android:exported="false"
            android:theme="@style/Theme.Transparent"
            android:launchMode="singleInstance" />

        <!-- 设置界面 -->
        <activity
            android:name=".ui.activity.SettingsActivity"
            android:exported="false"
            android:parentActivityName=".ui.activity.MainActivity" />

        <!-- 前台服务：截屏 + OCR + 超级岛通知 -->
        <!--
            Android 14 (API 34) 限制：
            - 必须声明 foregroundServiceType，否则 startForegroundService() 抛异常
            - mediaProjection 类型要求持有 token 才能调用 startForeground()
            - 方案：使用 specialUse 类型，无需 token 即可调用 startForeground()
            - targetSdk 降为 33 以避开 Android 14 的严格校验
        -->
        <service
            android:name=".service.PickCodeService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <!-- specialUse 类型必须在 Manifest 中声明使用原因（Android 14+） -->
            <property
                android:name="android.app.foreground_service_special_use_reason"
                android:value="后台截屏识别验证码，需常驻通知保障服务不被系统杀掉" />
        </service>

        <!-- Quick Settings Tile（快捷开关） -->
        <service
            android:name=".tile.PickCodeTileService"
            android:exported="true"
            android:icon="@drawable/ic_tile"
            android:label="@string/tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- 开机自启广播 -->
        <receiver
            android:name=".service.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!--
            复制验证码广播接收器（超级岛 Action 按钮触发）
            接收来自小米超级岛"复制验证码"按钮的广播
            Action: com.pickcode.ACTION_COPY_CODE
        -->
        <receiver
            android:name=".service.CopyCodeReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.pickcode.ACTION_COPY_CODE" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
